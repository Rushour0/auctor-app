{
  "name": "linkup-collector",
  "description": "Collect deduplicated industry sources through the auctor-memory MCP server.",
  "command": ["mcp", "auctor-memory", "sync_industry_trends"],
  "input_schema": {"type": "object", "properties": {"workspace_id": {"type": "string"}, "topics": {"type": "array", "items": {"type": "string"}}, "queries": {"type": "array", "items": {"type": "string"}}, "depth": {"type": "string"}}, "required": ["workspace_id", "topics"]},
  "output_schema": {"type": "object"},
  "allowed_agents": ["trend_researcher"],
  "risk_level": "low",
  "approval_policy": "none",
  "timeout_s": 120,
  "retry_policy": {"max_attempts": 2, "backoff_s": 3}
}
