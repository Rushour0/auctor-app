{
  "name": "linkup-auth",
  "description": "Validate Linkup credentials through the auctor-memory MCP server.",
  "command": ["mcp", "auctor-memory", "verify_linkup_connection"],
  "input_schema": {"type": "object", "properties": {"workspace_id": {"type": "string"}}, "required": ["workspace_id"]},
  "output_schema": {"type": "object"},
  "allowed_agents": ["researcher", "trend_researcher"],
  "risk_level": "low",
  "approval_policy": "none",
  "timeout_s": 30,
  "retry_policy": {"max_attempts": 1, "backoff_s": 0}
}
