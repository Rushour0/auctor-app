{
  "name": "sync_posthog",
  "provider": "auctor-memory",
  "description": "Collect product events and event-count metrics from PostHog.",
  "writes": ["raw_records", "events", "metric_observations", "sync_states"],
  "required_env": ["MONGODB_URI", "POSTHOG_HOST", "POSTHOG_PROJECT_ID", "POSTHOG_PERSONAL_API_KEY"]
}
