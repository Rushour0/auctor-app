{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://auctor.rushour0.com/schemas/source-signal.schema.json",
  "title": "Auctor source signal",
  "type": "object",
  "required": [
    "workspace_id",
    "source",
    "external_id",
    "occurred_at",
    "provenance"
  ],
  "properties": {
    "workspace_id": { "type": "string", "minLength": 1 },
    "source": { "enum": ["github", "linkup", "posthog"] },
    "external_id": { "type": "string", "minLength": 1 },
    "event_type": { "type": "string" },
    "title": { "type": ["string", "null"] },
    "body": { "type": ["string", "null"] },
    "occurred_at": { "type": "string", "format": "date-time" },
    "attributes": { "type": "object" },
    "provenance": {
      "type": "object",
      "required": ["source", "external_id", "raw_record_id", "collected_at"],
      "properties": {
        "source": { "enum": ["github", "linkup", "posthog"] },
        "external_id": { "type": "string" },
        "raw_record_id": { "type": "string" },
        "source_url": { "type": ["string", "null"] },
        "collected_at": { "type": "string", "format": "date-time" },
        "collector_version": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
