# Paste into Coolify → auctor-app Application → Environment Variables.
# Fill in real values for anything currently blank — this file itself only
# ever holds placeholders and is safe to commit.

COMPOSE_PROFILES=prod
VERSION=latest

# Required — CORS breaks silently if this doesn't match the real frontend
# domain exactly (per the hyphenated-hostname gotcha ludexel-app's own docs
# flag: defaults assume dot-subdomains, ours uses hyphens).
CORS_ALLOW_ORIGINS=https://auctor-app.rushour0.com

AGENCY_ENV=production
SITE_MAX_RETRY_ATTEMPTS=2
CONTENT_MAX_RETRY_ATTEMPTS=1

# Operator login (GitHub OAuth into the dashboard itself) — distinct from
# GITHUB_TOKEN/GITHUB_CLIENT_ID below, which are the data-collector app
# connection, not this. Required for /api/auth/github/* to work at all.
GITHUB_LOGIN_CLIENT_ID=
GITHUB_LOGIN_CLIENT_SECRET=
GITHUB_LOGIN_REDIRECT_URI=https://auctor-api.rushour0.com/api/auth/github/callback
OPERATOR_SESSION_SECRET=
# Username/password fallback login (POST /api/auth/login), alongside GitHub OAuth.
OPERATOR_LOGIN_USERNAME=
OPERATOR_LOGIN_PASSWORD=

# Public, no-signup "suggest my posts" demo (POST /api/demo/suggest) — needs
# LINKUP_API_KEY + OPENAI_API_KEY (both below) or it fails loud
# ("...temporarily unavailable") rather than fabricating. Drafts via gpt-5.6-terra.
DEMO_RATE_LIMIT_PER_DAY=3

# Partner integrations — blank = that specialist/tool fails loud, not silently
LINKUP_API_KEY=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
ELEVENLABS_API_KEY=
HEYGEN_API_KEY=
OPENAI_API_KEY=
GITHUB_TOKEN=
# The data-collector GitHub App registration (service/auctor/config.py) — App ID is
# the numeric GitHub-internal id, Client ID is the Iv23li... OAuth identifier for the
# SAME app. Distinct from GITHUB_LOGIN_CLIENT_ID above.
GITHUB_APP_ID=
GITHUB_CLIENT_ID=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
TWITTER_API_KEY=
TWITTER_API_SECRET=
WHATSAPP_BUSINESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
DODO_API_KEY=
DODO_WEBHOOK_SECRET=
